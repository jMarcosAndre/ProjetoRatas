generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  // No Prisma 7 com prisma.config.ts, a URL não fica mais aqui
}

enum SistemaRole {
  ADMIN
  USER
}

enum ProjetoRoleType {
  RESPONSAVEL
  COLABORADOR
  LEITOR
}

enum PeriodoMorte {
  PRE_IMPLANTACAO
  LOGO_APOS_IMPLANTACAO
  FINAL_PRENHEZ
  VIVO
}

// --- MODELS ---

model User {
  id                  Int           @id @default(autoincrement())
  nome                String
  email               String        @unique
  password            String
  roleSistema         SistemaRole   
  
  projetoResponsavel  Projeto?      
  participacoes       ProjetoRole[] 
}

model Projeto {
  id                   Int           @id @default(autoincrement())
  nome                 String
  descricao            String?
  responsavelProjetoId Int           @unique 
  participantes        ProjetoRole[]

  responsavel          User          @relation(fields: [responsavelProjetoId], references: [id])
}

model ProjetoRole {
  id        Int             @id @default(autoincrement())
  userId    Int
  role      ProjetoRoleType @default(LEITOR)
  projetoId Int

  user    User    @relation(fields: [userId], references: [id])
  projeto Projeto @relation(fields: [projetoId], references: [id])

  @@unique([userId, projetoId]) 
}

model Rata {
  id                   Int           @id @default(autoincrement())
  identificacao        Int 
  numero               Int           @unique
  linhagem             String
  prenhez              Boolean       @default(false)
  dataNascimento       DateTime
  dataFinalExperimento DateTime
  inclusao             Boolean       
  morte                Boolean?      
  
  fetos                Feto[]
  historicoDados       DadosGerais[]
  gestacao             Gestacao?
  totg                 TOTG?         
  bioquimica           DosagensBioquimicas?
  estresseOxidativo    EstresseOxidativo?

  grupoId              Int 
  grupo                Grupo         @relation(fields: [grupoId], references: [id])
}

model Grupo {
  id        Int      @id @default(autoincrement())
  nomeGrupo String
  ratas     Rata[]
}

model Gestacao {
  id                  Int      @id @default(autoincrement())
  dataPrenhez         DateTime
  rataId              Int      @unique 
  
  ganhoPesoMaterno    Float?
  nCorposLuteos       Int?
  nImplantacoes       Int?
  nFetosVivos         Int?
  nFetosMortos        Int?
  nMortesEmbrionarias Int?
  
  perdasPreImplantacao Float?
  perdasPosImplantacao Float? 
  pesoTotalNinhada     Float? 

  rata Rata @relation(fields: [rataId], references: [id])
}

model Feto {
  id            Int          @id @default(autoincrement())
  identificacao String       
  statusPeriodo PeriodoMorte @default(VIVO)
  pesoFeto      Float?
  pesoPlacenta  Float?
  dataMorte     DateTime?    

  rataId Int
  rata   Rata @relation(fields: [rataId], references: [id])
}

model DadosGerais {
  id           Int      @id @default(autoincrement())
  rataId       Int
  peso         Float
  consumoAgua  Float
  consumoRacao Float
  dataMedicao  DateTime

  rata Rata @relation(fields: [rataId], references: [id])
}

model TOTG {
  id          Int     @id @default(autoincrement())
  rataId      Int     @unique 
  t0          Float
  t30         Float
  t60         Float
  t120        Float
  diagnostico String? 

  rata Rata @relation(fields: [rataId], references: [id])
}

model EstresseOxidativo {
  id                      Int     @id @default(autoincrement())
  absorsanciaAmostra      Float 
  proteinaTotal           Float 
  concentracaoHemoglobina Float 
  tbars                   Float 
  tioisReduzidos          Float 
  peroxidoHidrogenio      Float   
  
  rataid                  Int     @unique
  rata                    Rata    @relation(fields: [rataid], references: [id])
}

model DosagensBioquimicas {
  id                          Int     @id @default(autoincrement())
  absorsanciaAmostra          Float 
  absorsanciaPadrao           Float 
  concentracaoTriglicerides   Float 
  concentracaoColesterolTotal Float 
  concentracaoGPT             Float 
  concentracaoVLDL            Float 

  rataid                      Int     @unique
  rata                        Rata    @relation(fields: [rataid], references: [id])
}