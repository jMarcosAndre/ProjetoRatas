generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  // No Prisma 7 com prisma.config.ts, a URL não fica mais aqui
}

enum GrupoExperimental {
  FDmod
  NDmod
  DMod
  Controle
}

enum SistemaRole {
  ADMIN
  USER
}

enum ProjetoStatus {
  EM_CURSO
  CONCLUIDO
  INTERROMPIDO
}

enum RoleProjeto{
  RESPONSAVEL
  COLABORADOR
}

enum PeriodoMorte {
  PRE_IMPLANTACAO
  LOGO_APOS_IMPLANTACAO
  FINAL_PRENHEZ
  VIVO
}

enum Linhagem {
  WISTAR
  SPRAGUE_DAWLEY
  SHR
  WAR
  OUTRO
}

// --- MODELS ---

model User {
  id                  Int           @id @default(autoincrement())
  nome                String
  email               String        @unique
  password            String
  roleSistema         SistemaRole
  projetoResponsavel  Projeto?
  projetos            ProjetoRole[]
}

model Projeto {
  id                   Int           @id @default(autoincrement())
  nome                 String
  descricao            String?
  responsavelProjetoId Int           @unique
  participantes        ProjetoRole[]
  status               ProjetoStatus @default(EM_CURSO)
  ratas                Rata[]

  responsavel          User          @relation(fields: [responsavelProjetoId], references: [id])
}

model ProjetoRole {
  id        Int             @id @default(autoincrement())
  role      RoleProjeto
  userId    Int
  projetoId Int

  user    User    @relation(fields: [userId], references: [id])
  projeto Projeto @relation(fields: [projetoId], references: [id])

  @@unique([userId, projetoId]) 
}

model Rata {
  id                   Int           @id @default(autoincrement())
  identificacao        Int
  numero               Int           @unique
  linhagem             Linhagem
  linhagemOutro        String?
  prenhez              Boolean       @default(false)
  dataNascimento       DateTime
  dataFinalExperimento DateTime
  recebeuSTZ           Boolean           @default(false)
  inclusao             Boolean           @default(false)
  morte                Boolean?
  grupo                GrupoExperimental?
  projetoId            Int
  projeto              Projeto       @relation(fields: [projetoId], references: [id])

  fetos                Feto[]
  historicoDados       DadosGerais[]
  gestacao             Gestacao?
  totg                 TOTG?

  // Estresse oxidativo
  hemoglobina          Hemoglobina?
  proteinaTotal        ProteinaTotal?
  tbars                TBARS?
  tioisReduzidos       TioisReduzidos?
  sod                  SOD?
  gshPx                GSHPx?
  h2o2                 H2O2?

  // Dosagens bioquímicas
  triglicerides        Triglicerides?
  colesterolTotal      ColesterolTotal?
  gpt                  GPT?
  got                  GOT?
  vldl                 VLDL?
}

model Gestacao {
  id                  Int      @id @default(autoincrement())
  dataPrenhez         DateTime
  rataId              Int      @unique 
  
  ganhoPesoMaterno    Float?
  nCorposLuteos       Int?
  nImplantacoes       Int?
  nFetosVivos         Int?
  nFetosMortos        Int?
  nMortesEmbrionarias Int?
  
  perdasPreImplantacao Float?
  perdasPosImplantacao Float? 
  pesoTotalNinhada     Float? 

  rata Rata @relation(fields: [rataId], references: [id])
}

model Feto {
  id            Int          @id @default(autoincrement())
  identificacao String
  statusPeriodo PeriodoMorte @default(VIVO)
  pesoFeto      Float?
  pesoPlacenta  Float?
  dataPrenhez   DateTime?
  dataMorte     DateTime?

  rataId Int
  rata   Rata @relation(fields: [rataId], references: [id])
}

model DadosGerais {
  id           Int      @id @default(autoincrement())
  rataId       Int
  peso         Float
  consumoAgua  Float
  consumoRacao Float
  dataMedicao  DateTime

  rata Rata @relation(fields: [rataId], references: [id])
}

model TOTG {
  id               Int      @id @default(autoincrement())
  rataId           Int      @unique
  dataRealizacao   DateTime
  t0               Float
  t30              Float
  t60              Float
  t120             Float
  diagnostico      String?

  rata Rata @relation(fields: [rataId], references: [id])
}

// --- ESTRESSE OXIDATIVO ---

model Hemoglobina {
  id            Int    @id @default(autoincrement())
  absAmostra    Float
  absBranco     Float
  concentracao  Float?  // calculado
  rataid        Int    @unique
  rata          Rata   @relation(fields: [rataid], references: [id])
}

model ProteinaTotal {
  id            Int    @id @default(autoincrement())
  valor         Float  // input do usuário (denominador alternativo ao Hb)
  rataid        Int    @unique
  rata          Rata   @relation(fields: [rataid], references: [id])
}

model TBARS {
  id            Int    @id @default(autoincrement())
  absAmostra    Float
  absBranco     Float
  concentracao  Float?  // calculado (nM/mg Hb ou PTN)
  rataid        Int    @unique
  rata          Rata   @relation(fields: [rataid], references: [id])
}

model TioisReduzidos {
  id            Int    @id @default(autoincrement())
  absAmostra    Float
  absBranco     Float
  concentracao  Float?  // calculado (mM/mg Hb ou PTN)
  rataid        Int    @unique
  rata          Rata   @relation(fields: [rataid], references: [id])
}

model SOD {
  id                  Int    @id @default(autoincrement())
  percentAutoxidacao  Float  // % auto-oxidação do pirogalol na amostra
  volumeAmostra       Float  // volume (mL) que inibe 50% do pirogalol
  atividade           Float?  // calculado (UI/g Hb)
  rataid              Int    @unique
  rata                Rata   @relation(fields: [rataid], references: [id])
}

model GSHPx {
  id            Int    @id @default(autoincrement())
  leitura1      Float  // leituras A340 consecutivas
  leitura2      Float
  leitura3      Float
  leitura4      Float
  atividade     Float?  // calculado (mM/min/mg Hb ou PTN)
  rataid        Int    @unique
  rata          Rata   @relation(fields: [rataid], references: [id])
}

model H2O2 {
  id            Int    @id @default(autoincrement())
  absAmostra    Float
  absBranco     Float
  concentracao  Float?  // calculado (µM/mg Hb ou PTN)
  rataid        Int    @unique
  rata          Rata   @relation(fields: [rataid], references: [id])
}

// --- DOSAGENS BIOQUÍMICAS ---

model Triglicerides {
  id            Int    @id @default(autoincrement())
  absAmostra    Float
  absPadrao     Float
  concentracao  Float?  // calculado (mg/dL)
  rataid        Int    @unique
  rata          Rata   @relation(fields: [rataid], references: [id])
}

model ColesterolTotal {
  id            Int    @id @default(autoincrement())
  absAmostra    Float
  absPadrao     Float
  concentracao  Float?  // calculado (mg/dL)
  rataid        Int    @unique
  rata          Rata   @relation(fields: [rataid], references: [id])
}

model GPT {
  id            Int    @id @default(autoincrement())
  absAmostra    Float
  concentracao  Float?  // calculado (U/L)
  rataid        Int    @unique
  rata          Rata   @relation(fields: [rataid], references: [id])
}

model GOT {
  id            Int    @id @default(autoincrement())
  absAmostra    Float
  concentracao  Float?  // calculado (U/L)
  rataid        Int    @unique
  rata          Rata   @relation(fields: [rataid], references: [id])
}

model VLDL {
  id            Int    @id @default(autoincrement())
  concentracao  Float?  // calculado (triglicérides / 5)
  rataid        Int    @unique
  rata          Rata   @relation(fields: [rataid], references: [id])
}